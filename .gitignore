# Virtual environments
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Jupyter
.ipynb_checkpoints/

# Raw data — never commit raw files to version control
data/raw/

# Data files
*.xlsx
*.csv

# Keep processed outputs for Streamlit Cloud deployment
!data/processed/*.csv
!data/processed/*.png

# Environment variables
.env
.env.*

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp

# MLflow — local experiment tracking (not for version control)
mlruns/
mlruns.db
*.db

# Build artifacts
dist/
build/
*.egg-info/
